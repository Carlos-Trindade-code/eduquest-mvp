# ===========================================
# Studdo MVP - Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local e preencha com seus valores reais:
#   cp .env.example .env.local
#
# NUNCA commite o .env.local no repositorio!

# Site URL (dominio oficial)
NEXT_PUBLIC_SITE_URL=https://www.studdo.com.br

# AI Provider (Gemini = gratis)
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# Anthropic (opcional, alternativa ao Gemini)
# ANTHROPIC_API_KEY=SUA_CHAVE_ANTHROPIC_AQUI

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
